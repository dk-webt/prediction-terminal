# ── Kalshi ──────────────────────────────────────────────────────────────────────
# API key from Kalshi dashboard
KALSHI_API_KEY=your-kalshi-api-key
# Path to RSA private key (used for signing REST + WS auth)
KALSHI_PRIVATE_KEY_PATH=~/.ssh/kalshi_private_key.pem

# ── Polymarket ─────────────────────────────────────────────────────────────────
# MetaMask private key (signer — signs orders, does NOT hold funds)
POLYMARKET_PRIVATE_KEY=0xYOUR_METAMASK_PRIVATE_KEY
# Safe/proxy wallet address from Polymarket Settings (holds USDC and positions)
POLYMARKET_WALLET_ADDRESS=0xYOUR_SAFE_WALLET_ADDRESS

# L2 API creds — derived from private key on first run.
# Server will log them to console on first startup — copy them here for faster startup.
# These authenticate CLOB REST requests. Do NOT regenerate unless needed.
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Builder keys — from Polymarket Settings → Builder section.
# Enables gasless trading (no POL needed for on-chain transactions).
# Optional but recommended for production bots.
POLYMARKET_BUILDER_KEY=
POLYMARKET_BUILDER_SECRET=
POLYMARKET_BUILDER_PASSPHRASE=

# ── Gemini (for semantic matching) ─────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
